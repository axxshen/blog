---
import Base from './Base.astro';
interface Props {
  title: string;
  description?: string;
  pubDate: Date;
  updatedDate?: Date;
  tags?: string[];
}
const { title, description, pubDate, updatedDate, tags } = Astro.props;
const fmt = (d: Date) => d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---
<Base title={title} description={description}>
  <article>
    <header>
      <div class="meta">
        <time>{fmt(pubDate)}</time>
        {updatedDate && <span class="updated">· updated {fmt(updatedDate)}</span>}
        {tags && tags.length > 0 && (
          <div class="tags">
            {tags.map(t => <span class="tag">{t}</span>)}
          </div>
        )}
      </div>
      <h1>{title}</h1>
      {description && <p class="desc">{description}</p>}
    </header>
    <div class="prose">
      <slot />
    </div>
  </article>
</Base>

<style>
  article { max-width: 100%; }

  header { margin-bottom: 2.5rem; padding-bottom: 1.5rem; border-bottom: 1px solid var(--border); }

  .meta { font-size: 0.85rem; color: var(--muted); margin-bottom: 0.75rem; display: flex; align-items: center; flex-wrap: wrap; gap: 0.5rem; }
  .updated { color: var(--muted); }
  .tags { display: flex; gap: 0.4rem; flex-wrap: wrap; }
  .tag { background: var(--surface); border: 1px solid var(--border); border-radius: 4px; padding: 0.1rem 0.5rem; font-size: 0.75rem; color: var(--muted); }

  h1 { font-size: 1.9rem; font-weight: 700; line-height: 1.2; letter-spacing: -0.02em; margin-bottom: 0.75rem; color: var(--text); }
  .desc { color: var(--muted); font-size: 1.05rem; line-height: 1.5; }

  .prose { font-size: 1.05rem; }
  .prose :global(h2) { font-size: 1.3rem; font-weight: 600; margin: 2rem 0 0.75rem; color: var(--text); }
  .prose :global(h3) { font-size: 1.1rem; font-weight: 600; margin: 1.5rem 0 0.5rem; color: var(--text); }
  .prose :global(p) { margin-bottom: 1.2rem; color: #d0d0d0; }
  .prose :global(ul), .prose :global(ol) { margin: 0 0 1.2rem 1.5rem; color: #d0d0d0; }
  .prose :global(li) { margin-bottom: 0.3rem; }
  .prose :global(strong) { color: var(--text); font-weight: 600; }
  .prose :global(code) { font-family: var(--mono); font-size: 0.9em; background: var(--surface); padding: 0.15em 0.4em; border-radius: 4px; }
  .prose :global(pre) { background: var(--surface); border: 1px solid var(--border); border-radius: 8px; padding: 1.25rem; overflow-x: auto; margin-bottom: 1.2rem; }
  .prose :global(pre code) { background: none; padding: 0; font-size: 0.9rem; }
  .prose :global(blockquote) { border-left: 3px solid var(--border); padding-left: 1rem; color: var(--muted); margin: 1rem 0 1.2rem; font-style: italic; }
  .prose :global(hr) { border: none; border-top: 1px solid var(--border); margin: 2rem 0; }
  .prose :global(a) { color: var(--accent); }
</style>
