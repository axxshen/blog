---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => data.status === 'published'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 5);

const fmt = (d: Date) => d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
---
<Base title="Ao Shen">
  <section class="hero">
    <h1>Ao Shen</h1>
    <p>I write about things I build and think about — AI systems, markets, career, and what it means to compound over time.</p>
  </section>

  {posts.length > 0 && (
    <section class="recent">
      <h2>Recent</h2>
      <ul>
        {posts.map(post => (
          <li>
            <a href={`${import.meta.env.BASE_URL}blog/${post.id}`}>{post.data.title}</a>
            <time>{fmt(post.data.pubDate)}</time>
          </li>
        ))}
      </ul>
      <a href={`${import.meta.env.BASE_URL}blog`} class="all">All posts →</a>
    </section>
  )}
</Base>

<style>
  .hero { margin-bottom: 3.5rem; padding-bottom: 2.5rem; border-bottom: 1px solid var(--border); }
  .hero h1 { font-size: 2rem; font-weight: 700; letter-spacing: -0.03em; margin-bottom: 0.75rem; }
  .hero p { color: var(--muted); font-size: 1.05rem; max-width: 520px; line-height: 1.6; }

  .recent h2 { font-size: 0.75rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; color: var(--muted); margin-bottom: 1.25rem; }
  ul { list-style: none; display: flex; flex-direction: column; gap: 0.1rem; }
  li { display: flex; justify-content: space-between; align-items: baseline; padding: 0.6rem 0; border-bottom: 1px solid var(--border); gap: 1rem; }
  li a { font-size: 1rem; color: var(--text); flex: 1; }
  li a:hover { color: var(--accent); text-decoration: none; }
  time { font-size: 0.8rem; color: var(--muted); white-space: nowrap; }
  .all { display: inline-block; margin-top: 1.25rem; font-size: 0.9rem; color: var(--muted); }
  .all:hover { color: var(--accent); text-decoration: none; }
</style>
